{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "scrapyard-io/scrapyard-io",
    "type": "project",
    "description": "The skeleton application for the ScrapyardIO framework.",
    "keywords": [
        "scrapyard-io",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4|^8.5|^8.6",
        "ext-fileinfo": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "scrapyard-io/framework": "^0.5.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout"
        ],
        "test": [],
        "post-autoload-dump": [
            "Fabricate\\Core\\ComposerScripts::postAutoloadDump",
            "@php workshop package:discover --ansi"
        ],
        "post-update-cmd": [],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [],
        "pre-package-uninstall": [
            "Fabricate\\Core\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "scrapyard-io": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "scrapyard-io/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "microscrap/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "dept-of-scrapyard-robotics/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
