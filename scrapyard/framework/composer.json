{
    "name": "scrapyard-io/framework",
    "description": "The ScrapyardIO Framework.",
    "keywords": ["framework", "scrapyard-io"],
    "license": "MIT",
    "version": "0.5.0",
    "homepage": "https://scrapyard-io.projectsaturnstudios.com",
    "support": {
        "issues": "https://github.com/scrapyard-io/framework/issues",
        "source": "https://github.com/scrapyard-io/framework"
    },
    "authors": [
        {
            "name": "Angel Gonzalez",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/container": "^13.0"
    },
    "suggest": {
        "ext-posi": "^0.5.0",
        "ext-ftdi": "^0.5.0",
        "microscrap/posix": "^0.5.1",
        "microscrap/ftdi": "^0.5.1",
        "microscrap/mpsse": "^0.5.1"
    },
    "replace": {
        "bare-metal/actuation": "self.version",
        "bare-metal/circuits": "self.version",
        "bare-metal/contracts": "self.version",
        "bare-metal/displays": "self.version",
        "bare-metal/framebuffers": "self.version",
        "bare-metal/gfx": "self.version",
        "bare-metal/sensors": "self.version",

        "waveforms/common": "self.version",
        "waveforms/contracts": "self.version",
        "waveforms/digital": "self.version",
        "waveforms/i2c": "self.version",
        "waveforms/spi": "self.version",
        "waveforms/pwm": "self.version",
        "waveforms/uart": "self.version",

        "scrapyard-io/nuts-and-bolts": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4"
    },
    "autoload": {
        "files": [
            "src/NutsAndBolts/Helpers/bytes.php",
            "src/NutsAndBolts/Helpers/support.php"
        ],
        "psr-4": {
            "GPIO\\": "src/GPIO/",
            "BareMetal\\": "src/BareMetal/",
            "ScrapyardIO\\NutsAndBolts\\": "src/NutsAndBolts/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.5.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
